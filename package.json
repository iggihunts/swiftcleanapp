{
  "name": "swiftclean",
  "version": "1.0.0",
  "description": "Open-source Mac cleaner, optimizer & malware scanner",
  "main": "src/main.js",
  "author": "SwiftClean Contributors",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --mac --publish never",
    "build:dmg": "electron-builder --mac dmg --publish never",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.swiftclean.macos",
    "productName": "SwiftClean",
    "copyright": "Copyright © 2025 SwiftClean Contributors",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "icon": "assets/icon.icns",
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.plist",
      "entitlementsInherit": "assets/entitlements.plist",
      "extendInfo": {
        "NSAppleEventsUsageDescription": "SwiftClean needs automation access to restart Finder and Dock.",
        "NSDesktopFolderUsageDescription": "SwiftClean needs access to scan and clean files on your desktop.",
        "NSDocumentsFolderUsageDescription": "SwiftClean needs access to scan files in Documents.",
        "NSDownloadsFolderUsageDescription": "SwiftClean needs access to scan files in Downloads."
      }
    },
    "dmg": {
      "title": "SwiftClean",
      "background": "assets/dmg-background.png",
      "window": { "width": 660, "height": 400 },
      "contents": [
        { "x": 180, "y": 190, "type": "file" },
        { "x": 480, "y": 190, "type": "link", "path": "/Applications" }
      ]
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "index.html",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bin/",
        "to": "bin/",
        "filter": ["**/*"]
      }
    ],
    "asar": true
  }
}
